    [Fact]
    public async Task ValueObjectPreflightDetectsRepairsAndClearsSqlSafeViolations()
    {
        if (!SqlTestDatabase.IsConfigured) { return; }
        var databaseName = $"{{ .Name }}_preflight_{Guid.NewGuid():N}";
        await using var database = new SqlTestDatabase(databaseName);
        await database.InitializeAsync();

        await using var context = database.CreateContext();
        Assert.Empty(await RunPreflightAsync(context));

{{ if not .ReadinessLengthRequired }}        var emptyId = Guid.NewGuid();
        await context.Database.ExecuteSqlRawAsync("INSERT INTO [{{ .ReadinessLengthEntity }}s] ([Id], [{{ .ReadinessLengthField }}]{{ range $entity := .Entities }}{{ if eq $entity.Name $.ReadinessLengthEntity }}{{ range $field := $entity.NonIDFields }}{{ if ne $field.Name $.ReadinessLengthField }}, [{{ $field.Name }}]{{ end }}{{ end }}{{ end }}{{ end }}) VALUES ({0}, N''{{ range $entity := .Entities }}{{ if eq $entity.Name $.ReadinessLengthEntity }}{{ range $field := $entity.NonIDFields }}{{ if ne $field.Name $.ReadinessLengthField }}, {{ $field.SQLSampleLiteral }}{{ end }}{{ end }}{{ end }}{{ end }})", emptyId);
        Assert.Empty(await RunPreflightAsync(context));
        await context.Database.ExecuteSqlRawAsync("DELETE FROM [{{ .ReadinessLengthEntity }}s] WHERE [Id] = {0}", emptyId);

{{ end }}
        var id = Guid.NewGuid();
        await context.Database.ExecuteSqlRawAsync("ALTER TABLE {{ .ReadinessLengthEntity }}s ALTER COLUMN {{ .ReadinessLengthField }} nvarchar({{ .ReadinessLengthMaxPlusOne }}) NOT NULL");
        await context.Database.ExecuteSqlRawAsync("INSERT INTO [{{ .ReadinessLengthEntity }}s] ([Id], [{{ .ReadinessLengthField }}]{{ range $entity := .Entities }}{{ if eq $entity.Name $.ReadinessLengthEntity }}{{ range $field := $entity.NonIDFields }}{{ if ne $field.Name $.ReadinessLengthField }}, [{{ $field.Name }}]{{ end }}{{ end }}{{ end }}{{ end }}) VALUES ({0}, REPLICATE(N'x', {{ .ReadinessLengthMaxPlusOne }}){{ range $entity := .Entities }}{{ if eq $entity.Name $.ReadinessLengthEntity }}{{ range $field := $entity.NonIDFields }}{{ if ne $field.Name $.ReadinessLengthField }}, {{ $field.SQLSampleLiteral }}{{ end }}{{ end }}{{ end }}{{ end }})", id);

        var violations = await RunPreflightAsync(context);
        var violation = Assert.Single(violations);
        Assert.Equal("{{ .ReadinessLengthEntity }}s", violation.TableName);
        Assert.Equal("{{ .ReadinessLengthField }}", violation.ColumnName);
        Assert.Equal(id, violation.RecordId);

        await using var transaction = await context.Database.BeginTransactionAsync();
        await context.Database.ExecuteSqlRawAsync("UPDATE [{{ .ReadinessLengthEntity }}s] SET [{{ .ReadinessLengthField }}] = {0} WHERE [Id] = {1}", "Repaired Value", id);
        await transaction.CommitAsync();

        await context.Database.ExecuteSqlRawAsync("ALTER TABLE {{ .ReadinessLengthEntity }}s ALTER COLUMN {{ .ReadinessLengthField }} nvarchar({{ .ReadinessLengthMax }}) NOT NULL");

        Assert.Empty(await RunPreflightAsync(context));
        var healthy = await new SqlReadinessProbe(context, NullLogger<SqlReadinessProbe>.Instance).CheckAsync(CancellationToken.None);
        Assert.Equal(ReadinessStatus.Ready, healthy.Status);
    }

